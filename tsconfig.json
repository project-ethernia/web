{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "lib": ["dom", "ES2017"],
    "strict": true,
    "noEmitOnError": true,
    "rootDir": "./public/assets/ts",
    "outDir": "./public/assets/js",
    "moduleResolution": "node",
    "allowJs": false
  },
  "include": ["public/assets/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
